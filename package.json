{
  "name": "my-books",
  "version": "0.1.0",
  "private": true,
  "description": "Personal Reading OS: NestJS + Prisma + SQLite app for books, reading taste, predictions and statistics.",
  "scripts": {
    "build": "nest build",
    "start": "nest start",
    "start:dev": "nest start --watch",
    "cli": "tsx src/cli/main.ts",
    "stats": "tsx src/cli/main.ts stats",
    "book:add": "tsx src/cli/main.ts book:add",
    "book:finish": "tsx src/cli/main.ts book:finish",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:seed": "tsx prisma/seed.ts",
    "db:reset": "prisma migrate reset --force"
  },
  "dependencies": {
    "@nestjs/common": "^10.4.15",
    "@nestjs/core": "^10.4.15",
    "@nestjs/platform-express": "^10.4.15",
    "@prisma/client": "^5.22.0",
    "commander": "^12.1.0",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1"
  },
  "devDependencies": {
    "@nestjs/cli": "^10.4.8",
    "@types/node": "^20.17.6",
    "prisma": "^5.22.0",
    "tsx": "^4.19.2",
    "typescript": "^5.6.3"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  }
}
